  "keyFeatures": [
    "Single binary deployment with embedded DuckDB",
    "Privacy-focused analytics without cookies",
    "Real-time dashboard with live visitor tracking",
    "Custom events and conversion funnels",
    "Retention cohort analysis",
    "Journey and session tracking",
    "Multi-website support",
    "First-class Next.js SDK integration",
    "Flexible authentication modes (none/password/local)",
    "GeoIP enrichment for location analytics"
  ],
  "publicApiSurface": [
    "POST /api/collect - Event ingestion endpoint",
    "GET /api/websites/:id/stats - Website statistics",
    "GET /api/websites/:id/pageviews - Pageview time series",
    "GET /api/websites/:id/metrics - Dimension breakdowns",
    "GET /api/websites/:id/realtime - Live visitor data",
    "GET /api/websites/:id/funnels - Funnel analysis",
    "GET /api/websites/:id/retention - Retention cohorts",
    "GET /api/websites/:id/journey - User journey analysis",
    "GET /api/websites - List all websites",
    "POST /api/websites - Create website",
    "PUT /api/websites/:id - Update website",
    "DELETE /api/websites/:id - Delete website",
    "POST /api/auth/login - User authentication",
    "POST /api/auth/setup - Initial setup",
    "GET /health - Health check endpoint"
  ]
